#!groovy

def branch = "${env.BRANCH}" != 'null' && "${env.BRANCH}" != '' ? "${env.BRANCH}" : 'master'
def test_tags = "${env.TEST_TAGS}".split(',')
def k8s_versions = "${env.K3S_KUBERNETES_VERSIONS}".split(',')
def all_cypress_tags = "${env.CYPRESS_TAGS}".split('\\|')
def baseConfig = env.VARS_YAML_CONFIG ?: ''

// Fail early on bad parameters
if (!baseConfig.trim()) {
    error("VARS_YAML_CONFIG is empty. Provide a valid YAML configuration.")
}
if (test_tags.length != k8s_versions.length) {
    error("TEST_TAGS (${test_tags.length}) and K3S_KUBERNETES_VERSIONS (${k8s_versions.length}) must have the same number of entries.")
}
['rancher_image_tag:', 'k3s_kubernetes_version:', 'cypress_tags:'].each { key ->
    if (!baseConfig.contains(key)) {
        error("VARS_YAML_CONFIG is missing '${key}' — required for multi-job overrides.")
    }
}

node {
  ansiColor('xterm') {
    withFolderProperties {
      withEnv(params.collect { "$it.key=$it.value" }) {
        test_tags.eachWithIndex { String rancher_version, int i ->
          String k8s_version = k8s_versions[i]
          for (String ct : all_cypress_tags) {
            def childConfig = baseConfig
                .replaceAll(/(?m)^rancher_image_tag:.*$/, "rancher_image_tag: \"${rancher_version}\"")
                .replaceAll(/(?m)^k3s_kubernetes_version:.*$/, "k3s_kubernetes_version: \"${k8s_version}\"")
                .replaceAll(/(?m)^cypress_tags:.*$/, "cypress_tags: \"${ct}\"")

            echo "RANCHER_TAG: ${rancher_version}, K8S_VERSION: ${k8s_version}, CYPRESS_TAGS: ${ct}"
            build(job: 'ui-automation-ansible-job', parameters: [
                text(name: 'VARS_YAML_CONFIG', value: childConfig),
                string(name: 'BRANCH', value: "${BRANCH}"),
                string(name: 'QA_INFRA_REPO', value: "${QA_INFRA_REPO}"),
                string(name: 'QA_INFRA_BRANCH', value: "${QA_INFRA_BRANCH}"),
                string(name: 'CLEANUP', value: "${CLEANUP}"),
                string(name: 'SLACK_NOTIFICATION', value: "${SLACK_NOTIFICATION}"),
                string(name: 'ANSIBLE_VERBOSITY', value: "${ANSIBLE_VERBOSITY}")
            ], propagate: false, wait: false)
          }
        }
      }
    }
  }
}