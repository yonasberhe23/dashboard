#!groovy

def upstream = !currentBuild.getBuildCauses('hudson.model.Cause$UserIdCause')
def buildtype = upstream ? 'RecurringRun' : 'AdHoc'
def branch = 'master'
def testExecutionResult = null
def testExitCode = null

if ("${env.branch}" != 'null' && "${env.branch}" != '') {
  branch = "${env.branch}"
}

if ("${env.CORRAL_PACKAGES_REPO}" != 'null' && "${env.CORRAL_PACKAGES_REPO}" != '') {
      corralRepo = "${env.CORRAL_PACKAGES_REPO}"
}

if ("${env.CORRAL_PACKAGES_BRANCH}" != 'null' && "${env.CORRAL_PACKAGES_BRANCH}" != '') {
      corralBranch = "${env.CORRAL_PACKAGES_BRANCH}"
}

node('harvester-vpn-1') {
  ansiColor('xterm') {
    withFolderProperties {
      paramsMap = []
      params.each {
        paramsMap << "$it.key=$it.value"
      }
      withCredentials([ string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                        string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY'),
                        string(credentialsId: 'AZURE_AKS_SUBSCRIPTION_ID', variable: 'AZURE_AKS_SUBSCRIPTION_ID'),
                        string(credentialsId: 'AZURE_CLIENT_ID', variable: 'AZURE_CLIENT_ID'),
                        string(credentialsId: 'AZURE_CLIENT_SECRET', variable: 'AZURE_CLIENT_SECRET'),
                        string(credentialsId: 'GKE_SERVICE_ACCOUNT', variable: 'GKE_SERVICE_ACCOUNT'),
                        string(credentialsId: 'PERCY_TOKEN', variable: 'PERCY_TOKEN'),
                        string(credentialsId: 'QASE_AUTOMATION_TOKEN', variable: 'QASE_AUTOMATION_TOKEN'),
                        string(credentialsId: 'UI_SLACK_BOT_TOKEN', variable: 'UI_SLACK_BOT_TOKEN'),
                        string(credentialsId: 'UI_SLACK_CHANNEL', variable: 'UI_SLACK_CHANNEL')
                        ]) {
        withEnv(paramsMap + ['TERM=xterm']) {
            try {
              stage('Pre-Clean') {
                sh """#!/bin/bash
                  set +x
                  mv "\${HOME}/dashboard" "\${HOME}/dashboard.old.\$\$" 2>/dev/null || true
                  rm -rf "\${HOME}/dashboard.old."* 2>/dev/null &
                  rm -f "\${HOME}/.env" 2>/dev/null || true
                  rm -rf "\${HOME}/.corral" 2>/dev/null || true
                  docker rm -f \$(docker ps -aq --filter ancestor=dashboard-test) 2>/dev/null || true
                  docker rmi -f dashboard-test 2>/dev/null || true
                """
              }
              stage('Checkout') {
                deleteDir()
                checkout([
                            $class: 'GitSCM',
                            branches: [[name: "*/${branch}"]],
                            extensions: scm.extensions + [[$class: 'CleanCheckout']],
                            userRemoteConfigs: scm.userRemoteConfigs
                        ])
                dir('./corral-packages') {
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "*/${corralBranch}"]],
                        extensions: scm.extensions + [[$class: 'CleanCheckout']],
                        userRemoteConfigs: [[url: 'https://github.com/' + corralRepo]]
                    ])
                    sh 'git --no-pager branch'
                    def ciFilename = 'dashboard-tests.yaml'
                    def ciConfigContents = env.CORRAL_PACKAGE_CONFIG
                    if (ciConfigContents != null) {
                        writeFile file: './packages/aws/' + ciFilename, text: ciConfigContents
                    }
                }
              }
              stage('Run Tests') {
                testExitCode = sh(script: 'cypress/jenkins/init.sh', returnStatus: true)
                if (testExitCode != 0) {
                  echo "init.sh exited with code ${testExitCode}"
                  currentBuild.result = 'UNSTABLE'
                }
              }
            } catch (err) {
              echo "Pipeline error: ${err}"
              currentBuild.result = 'UNSTABLE'
            } finally {
              stage('Grab Results') {
                // Safe to run even if init.sh failed
                sh 'cp ${HOME}/dashboard/results.xml . || true'
                sh 'mkdir -p html && cp -r ${HOME}/dashboard/cypress/reports/html/* html/ || true'
              }
              if ("${env.CLEANUP}".toLowerCase() == 'true') {
                stage('Clean Test Environment') {
                  sh """#!/bin/bash
                    export PATH=\$PATH:${WORKSPACE}/bin
                    source cypress/jenkins/utils.sh
                    set +x
                    corrals=\$( corral list | grep -v "NAME" | grep -v "-" | cut -d' ' -f 2 )
                    for corral in \$corrals; do clean_corral delete \$corral; done
                  """
                }
              }
              stage('Cleanup Executor') {
                sh """#!/bin/bash
                  set +x
                  # Remove credentials file
                  rm -f "\${HOME}/.env" || true
                  # Remove cloned dashboard (move-then-delete avoids NFS/overlayfs race)
                  mv "\${HOME}/dashboard" "\${HOME}/dashboard.old.\$\$" 2>/dev/null || true
                  rm -rf "\${HOME}/dashboard.old."* 2>/dev/null || true
                  # Remove corral config to prevent stale vars leaking between runs
                  rm -rf "\${HOME}/.corral" || true
                  # Remove stale Docker containers and image
                  docker rm -f \$(docker ps -aq --filter ancestor=dashboard-test) 2>/dev/null || true
                  docker rmi -f dashboard-test 2>/dev/null || true
                """
              }
              try {
                stage('Test Report') {
                    if (fileExists('results.xml')) {
                        junit testResults: '**/results.xml', allowEmptyResults: true

                        def resultsContent = readFile('results.xml').trim()
                        if (resultsContent.contains('<failure')) {
                            testExecutionResult = 'FAILURE'
                        } else if (resultsContent.contains('<testcase')) {
                            testExecutionResult = 'SUCCESS'
                        } else {
                            testExecutionResult = null
                        }
                    } else {
                        testExecutionResult = null
                    }
                    publishHTML(target : [allowMissing: false,
                      alwaysLinkToLastBuild: true,
                      keepAll: true,
                      // The path is relative to ${WORKSPACE}
                      reportDir: 'html',
                      reportFiles: 'index.html',
                      reportName: 'html-report',
                      reportTitles: 'Report'])
                }
              }
              catch (err) {
                echo 'Error in Test Report stage: ' + err
                // Only set testExecutionResult if it's null and tests actually ran
                // Check XML to determine if tests passed or failed, not just assume FAILURE
                if (testExecutionResult == null && fileExists('results.xml')) {
                    def resultsContent = readFile('results.xml').trim()
                    if (resultsContent.contains('<testcase')) {
                        // Tests ran - check if they failed or passed
                        if (resultsContent.contains('<failure')) {
                            testExecutionResult = 'FAILURE'
                        } else {
                            testExecutionResult = 'SUCCESS'
                        }
                    }
                }
                currentBuild.result = 'UNSTABLE'
              }

              // test failure -> FAILURE (Slack: FAILED)
              // pipeline/env failure -> UNSTABLE
              if (currentBuild.result == 'UNSTABLE' || testExecutionResult == 'FAILURE') {
                  if ("${env.SLACK_NOTIFICATION}".toLowerCase() != 'false') {
                      withEnv(["SLACK_BUILD_STATUS=${testExecutionResult == 'FAILURE' ? 'FAILURE' : 'UNSTABLE'}"]) {
                          sh 'cypress/jenkins/slack-notification.sh $SLACK_BUILD_STATUS'
                      }
                  }
              }
            }
        }
                        }
    }
  }
}
